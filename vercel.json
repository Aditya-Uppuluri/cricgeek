{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "web": {
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "insights": {
      "entrypoint": "insights_service/main.py",
      "routePrefix": "/_insights",
      "framework": "fastapi",
      "memory": 2048,
      "maxDuration": 120,
      "includeFiles": [
        "ai_service/t20_api.py",
        "ai_service/t20_insights.py",
        "capstone cric/cricket_metrics.py",
        "capstone cric/evaluator.py",
        "capstone cric/outputs/aggregated_df.pkl",
        "capstone cric/outputs/bowling_over_df.pkl",
        "capstone cric/outputs/entries_with_perf.pkl",
        "capstone cric/outputs/eval_results.pkl",
        "capstone cric/outputs/filtered_df.pkl",
        "capstone cric/outputs/player_gender_map.pkl",
        "capstone cric/outputs/player_image_urls.json",
        "capstone cric/outputs/player_team_map.json",
        "capstone cric/outputs/team_players_map.json",
        "capstone cric/outputs/teams_list.pkl"
      ]
    }
  }
}
