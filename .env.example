# Database connection for MySQL
DATABASE_URL="mysql://root:password@localhost:3306/cricgeek"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Cricket data provider (SportMonks only)
SPORTMONKS_API_TOKEN=""
SPORTMONKS_BASE_URL="https://cricket.sportmonks.com/api/v2.0"

# Commentary transcription
DEEPGRAM_API_KEY=""
DEEPGRAM_MODEL="nova-3"
AI_SERVICE_URL="http://127.0.0.1:8000"

# Ollama via Cloudflare Tunnel
OLLAMA_URL="https://ollama-api.<MY_DOMAIN>"
OLLAMA_BASE_URL="https://ollama-api.<MY_DOMAIN>"
OLLAMA_MODEL="qwen3.5:latest"
OLLAMA_BQS_MODEL="qwen3.5:latest"
OLLAMA_MATCH_MODEL="qwen3.5:latest"
OLLAMA_SHARED_SECRET="<MY_SHARED_SECRET>"

# Optional web fact-check backends
TAVILY_API_KEY=""
SERPER_API_KEY=""
FACT_CHECK_HISTORICAL_ENABLED="true"
FACT_CHECK_SEARCH_DEPTH="basic"
FACT_CHECK_MAX_WEB_CLAIMS="3"
FACT_CHECK_ALLOWED_DOMAINS="espncricinfo.com,icc-cricket.com,cricbuzz.com,wisden.com,sportstar.thehindu.com,thehindu.com,bbc.com,reuters.com,bcci.tv,cricket.com.au,ecb.co.uk,pcb.com.pk"
