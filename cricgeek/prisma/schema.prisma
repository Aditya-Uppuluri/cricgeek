generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid()) @db.VarChar(30)
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  password      String    @db.VarChar(255)
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  role          String    @default("user") @db.VarChar(20) // user, moderator, admin
  avatar        String?   @db.VarChar(500)
  bio           String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  blogs         Blog[]
  reports       Report[]
  comments      Comment[]
  writerProfile WriterProfile?
  writerDNA     WriterDNA?
  badges        WriterBadge[]
  achievements  WriterAchievement[]
}

model Blog {
  id          String    @id @default(cuid()) @db.VarChar(30)
  title       String    @db.VarChar(200)
  content     String    @db.LongText
  excerpt     String?   @db.Text
  slug        String    @unique @db.VarChar(300)
  status      String    @default("pending") @db.VarChar(20) // pending, approved, rejected, featured
  authorId    String    @db.VarChar(30)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags        String?   @db.VarChar(500)
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]
  reports     Report[]
  score       BlogScore?
}

model Comment {
  id        String   @id @default(cuid()) @db.VarChar(30)
  content   String   @db.Text
  blogId    String   @db.VarChar(30)
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  authorId  String   @db.VarChar(30)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Report {
  id        String   @id @default(cuid()) @db.VarChar(30)
  reason    String   @db.VarChar(200)
  details   String?  @db.Text
  blogId    String   @db.VarChar(30)
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  userId    String   @db.VarChar(30)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("pending") @db.VarChar(20) // pending, reviewed, dismissed
  createdAt DateTime @default(now())
}

model Contest {
  id          String   @id @default(cuid()) @db.VarChar(30)
  title       String   @db.VarChar(200)
  description String   @db.Text
  rules       String?  @db.Text
  startDate   DateTime
  endDate     DateTime
  status      String   @default("upcoming") @db.VarChar(20) // upcoming, active, ended
  prize       String?  @db.VarChar(200)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeaturedContent {
  id          String   @id @default(cuid()) @db.VarChar(30)
  title       String   @db.VarChar(200)
  description String?  @db.Text
  imageUrl    String?  @db.VarChar(500)
  linkUrl     String   @db.VarChar(500)
  type        String   @db.VarChar(30) // match, blog, analysis
  priority    Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── AI Scoring & Writer Profile Models ──────────────────────────────

model WriterProfile {
  id              String   @id @default(cuid()) @db.VarChar(30)
  userId          String   @unique @db.VarChar(30)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  averageBQS      Float    @default(0)       // Rolling Blog Quality Score average
  totalBlogs      Int      @default(0)
  totalViews      Int      @default(0)
  totalComments   Int      @default(0)
  bcs             Float    @default(0)       // Blog Consistency Score
  archetype       String   @default("rookie") @db.VarChar(30) // analyst, storyteller, etc.
  level           Int      @default(1)
  xp              Int      @default(0)
  streak          Int      @default(0)       // Consecutive weeks with a blog
  bestBQS         Float    @default(0)
  featuredCount   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlogScore {
  id                  String   @id @default(cuid()) @db.VarChar(30)
  blogId              String   @unique @db.VarChar(30)
  blog                Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  bqs                 Float    @default(0)       // Final Blog Quality Score (0-100)
  // Model Scores
  toneScore           Float    @default(0)       // RoBERTa sentiment (0-100)
  toxicityScore       Float    @default(0)       // Toxic-BERT (0-100, lower=better)
  originalityScore    Float    @default(0)       // MiniLM embedding analysis (0-100)
  coherenceScore      Float    @default(0)       // MiniLM paragraph flow (0-100)
  archetypeLabel      String   @default("unknown") @db.VarChar(30)
  archetypeConfidence Float    @default(0)
  // NER & Stats
  entitiesFound       Int      @default(0)       // BERT-NER detected entities
  statsFound          Int      @default(0)       // Stats extracted
  statsVerified       Int      @default(0)       // Stats verified via Sportmonks
  statAccuracy        Float    @default(0)       // % accuracy
  // Rule Engine
  constructiveness    Float    @default(0)       // (0-100)
  evidencePresence    Float    @default(0)       // (0-100)
  counterAcknowledge  Float    @default(0)       // (0-100)
  positionClarity     Float    @default(0)       // (0-100)
  infoDensity         Float    @default(0)       // (0-100)
  repetitionPenalty   Float    @default(0)       // (0-100, lower=more repeats)
  completeness        Float    @default(0)       // (0-100)
  // Meta
  wordCount           Int      @default(0)
  lexicalDiversity    Float    @default(0)
  sentenceVariety     Float    @default(0)
  processingStatus    String   @default("pending") @db.VarChar(20)
  processingTimeMs    Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model WriterDNA {
  id          String   @id @default(cuid()) @db.VarChar(30)
  userId      String   @unique @db.VarChar(30)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyst     Float    @default(50)  // Data-driven analysis strength (0-100)
  storyteller Float    @default(50)  // Narrative/story strength (0-100)
  critic      Float    @default(50)  // Critical evaluation strength (0-100)
  reporter    Float    @default(50)  // Factual reporting strength (0-100)
  debater     Float    @default(50)  // Argumentation strength (0-100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WriterBadge {
  id          String   @id @default(cuid()) @db.VarChar(30)
  userId      String   @db.VarChar(30)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge       String   @db.VarChar(50) // first_blood, century_maker, stat_master, etc.
  title       String   @db.VarChar(100)
  description String   @db.Text
  tier        String   @default("bronze") @db.VarChar(20) // bronze, silver, gold, platinum
  iconUrl     String?  @db.VarChar(500)
  earnedAt    DateTime @default(now())

  @@unique([userId, badge])
}

model WriterAchievement {
  id          String   @id @default(cuid()) @db.VarChar(30)
  userId      String   @db.VarChar(30)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement String   @db.VarChar(50) // blogs_5, blogs_10, views_1000, bqs_90, etc.
  title       String   @db.VarChar(100)
  description String   @db.Text
  milestone   Int      @default(0)  // Numeric milestone value
  earnedAt    DateTime @default(now())

  @@unique([userId, achievement])
}
