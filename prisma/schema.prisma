generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                  @id @default(cuid()) @db.VarChar(30)
  name               String                  @db.VarChar(100)
  email              String                  @unique @db.VarChar(255)
  phone              String?                 @db.VarChar(20)
  password           String                  @db.VarChar(255)
  emailVerified      Boolean                 @default(false)
  phoneVerified      Boolean                 @default(false)
  role               String                  @default("user") @db.VarChar(20)
  avatar             String?                 @db.VarChar(500)
  bio                String?                 @db.Text
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  blogs              Blog[]
  comments           Comment[]
  commentarySessions LiveCommentarySession[]
  reports            Report[]
  achievements       WriterAchievement[]
  badges             WriterBadge[]
  writerDNA          WriterDNA?
  writerProfile      WriterProfile?
}

model Blog {
  id        String     @id @default(cuid()) @db.VarChar(30)
  title     String     @db.VarChar(200)
  content   String     @db.LongText
  excerpt   String?    @db.Text
  slug      String     @unique @db.VarChar(300)
  status    String     @default("pending") @db.VarChar(20)
  authorId  String     @db.VarChar(30)
  tags      String?    @db.VarChar(500)
  views     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  matchTag  String?    @db.VarChar(100)
  runs      Int        @default(0)
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  score     BlogScore?
  comments  Comment[]
  reports   Report[]

  @@index([authorId], map: "Blog_authorId_fkey")
}

model Comment {
  id        String   @id @default(cuid()) @db.VarChar(30)
  content   String   @db.Text
  blogId    String   @db.VarChar(30)
  authorId  String   @db.VarChar(30)
  parentId  String?  @db.VarChar(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  @@index([authorId], map: "Comment_authorId_fkey")
  @@index([blogId], map: "Comment_blogId_fkey")
  @@index([parentId], map: "Comment_parentId_fkey")
  @@index([blogId, createdAt], map: "Comment_blogId_createdAt_idx")
}

model Report {
  id        String   @id @default(cuid()) @db.VarChar(30)
  reason    String   @db.VarChar(200)
  details   String?  @db.Text
  blogId    String   @db.VarChar(30)
  userId    String   @db.VarChar(30)
  status    String   @default("pending") @db.VarChar(20)
  createdAt DateTime @default(now())
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([blogId], map: "Report_blogId_fkey")
  @@index([userId], map: "Report_userId_fkey")
}

model Contest {
  id          String   @id @default(cuid()) @db.VarChar(30)
  title       String   @db.VarChar(200)
  description String   @db.Text
  rules       String?  @db.Text
  startDate   DateTime
  endDate     DateTime
  status      String   @default("upcoming") @db.VarChar(20)
  prize       String?  @db.VarChar(200)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeaturedContent {
  id          String   @id @default(cuid()) @db.VarChar(30)
  title       String   @db.VarChar(200)
  description String?  @db.Text
  imageUrl    String?  @db.VarChar(500)
  linkUrl     String   @db.VarChar(500)
  type        String   @db.VarChar(30)
  priority    Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WriterProfile {
  id            String   @id @default(cuid()) @db.VarChar(30)
  userId        String   @unique @db.VarChar(30)
  averageBQS    Float    @default(0)
  totalBlogs    Int      @default(0)
  totalViews    Int      @default(0)
  totalComments Int      @default(0)
  bcs           Float    @default(0)
  archetype     String   @default("fan") @db.VarChar(30)
  level         Int      @default(1)
  xp            Int      @default(0)
  streak        Int      @default(0)
  bestBQS       Float    @default(0)
  featuredCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  statAccuracy  Float    @default(0)
  totalRuns     Int      @default(0)
  writerTitle   String   @default("") @db.VarChar(50)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BlogScore {
  id                  String   @id @default(cuid()) @db.VarChar(30)
  blogId              String   @unique @db.VarChar(30)
  bqs                 Float    @default(0)
  toneScore           Float    @default(0)
  toxicityScore       Float    @default(0)
  originalityScore    Float    @default(0)
  coherenceScore      Float    @default(0)
  archetypeLabel      String   @default("unknown") @db.VarChar(30)
  archetypeConfidence Float    @default(0)
  entitiesFound       Int      @default(0)
  statsFound          Int      @default(0)
  statsVerified       Int      @default(0)
  statAccuracy        Float    @default(0)
  constructiveness    Float    @default(0)
  evidencePresence    Float    @default(0)
  counterAcknowledge  Float    @default(0)
  positionClarity     Float    @default(0)
  infoDensity         Float    @default(0)
  repetitionPenalty   Float    @default(0)
  completeness        Float    @default(0)
  wordCount           Int      @default(0)
  lexicalDiversity    Float    @default(0)
  sentenceVariety     Float    @default(0)
  processingStatus    String   @default("pending") @db.VarChar(20)
  processingTimeMs    Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  blog                Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
}

model WriterDNA {
  id          String   @id @default(cuid()) @db.VarChar(30)
  userId      String   @unique @db.VarChar(30)
  analyst     Float    @default(25)
  storyteller Float    @default(25)
  debater     Float    @default(25)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  fan         Float    @default(25)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WriterBadge {
  id          String   @id @default(cuid()) @db.VarChar(30)
  userId      String   @db.VarChar(30)
  badge       String   @db.VarChar(50)
  title       String   @db.VarChar(100)
  description String   @db.Text
  tier        String   @default("bronze") @db.VarChar(20)
  iconUrl     String?  @db.VarChar(500)
  earnedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge])
}

model WriterAchievement {
  id          String   @id @default(cuid()) @db.VarChar(30)
  userId      String   @db.VarChar(30)
  achievement String   @db.VarChar(50)
  title       String   @db.VarChar(100)
  description String   @db.Text
  milestone   Int      @default(0)
  earnedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievement])
}

model LiveCommentarySession {
  id          String                @id @default(cuid()) @db.VarChar(30)
  matchId     String                @db.VarChar(100)
  matchName   String                @db.VarChar(200)
  matchType   String                @db.VarChar(30)
  status      String                @default("live") @db.VarChar(20)
  moderatorId String                @db.VarChar(30)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  endedAt     DateTime?
  entries     LiveCommentaryEntry[]
  moderator   User                  @relation(fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([matchId])
  @@index([moderatorId], map: "LiveCommentarySession_moderatorId_fkey")
}

model LiveCommentaryEntry {
  id        String                @id @default(cuid()) @db.VarChar(30)
  sessionId String                @db.VarChar(30)
  text      String                @db.Text
  overText  String?               @db.VarChar(20)
  source    String                @default("typed") @db.VarChar(10)
  createdAt DateTime              @default(now())
  session   LiveCommentarySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}
